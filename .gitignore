# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
*.pyc

# ROS2
# Build artifacts belong inside ros2_ws/ only - never at repo root
install/
log/
build/

# ros2_ws build artifacts (allowed here, not root)
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# PlatformIO
# Build artifacts belong inside firmware/ only - never at repo root
.pio/

# Firmware PlatformIO artifacts (allowed inside firmware/, not root)
firmware/**/.pio/
firmware/**/*.hex
firmware/**/*.bin
firmware/**/*.elf
firmware/**/*.map

# STM32 CMake build
firmware/stm32_chassis/build/
firmware/stm32_chassis/cmake-build-*/

# Optional micro-ROS precompiled libraries (large binaries - managed separately)
firmware/stm32_chassis/micro_ros_lib/libmicroros.a
firmware/stm32_chassis/micro_ros_lib/include/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace

# Environment / secrets
.env
*.env.local
deployment/.env

# Logs
*.log
